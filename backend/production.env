# Production Environment Variables Template
# Rename this to .env in your production environment or set these on your hosting provider

# Server Settings
PORT=8000
NODE_ENV=production

# Database Settings
# Use your MongoDB Atlas URI here
MONGODB_URI_ATLAS=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gst_reconciliation?retryWrites=true&w=majority

# Security Settings
# Generate a long random string for JWT_SECRET
JWT_SECRET=your_super_secret_production_key_here
JWT_EXPIRE=7d

# Frontend Settings
# The URL of your deployed application
FRONTEND_URL=https://your-app-name.onrender.com

# File Upload Settings
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
